diff --git a/build/config/mac/BUILD.gn b/build/config/mac/BUILD.gn
index 56238a14ae..71974bef55 100644
--- a/build/config/mac/BUILD.gn
+++ b/build/config/mac/BUILD.gn
@@ -37,6 +37,20 @@ config("compiler") {
 
   ldflags = common_mac_flags
 
+  # Swift is normally iOS-only; the Mori overlay compiles SwiftUI on macOS.
+  # Provide the swiftc target triple and SDK so swift_source_set targets build.
+  # Mori's SwiftUI uses macOS 14 APIs; compile Swift against a 14.0 minimum
+  # even though the rest of the binary targets $mac_deployment_target (this is
+  # the expected Swift deployment-target mismatch warning, see BUILDING.md).
+  swiftflags = [
+    "-target",
+    "$clang_arch-apple-macos14.0",
+    "-sdk",
+    rebase_path(sysroot, root_build_dir),
+    "-swift-version",
+    "5",
+  ]
+
   # ld64 defaults to fixup chains on macOS 12+ when targeting arm64 and on
   # macOS 13+ when targeting x86_64.
   # ld64.lld currently defaults to it on macOS 13+.
@@ -50,6 +64,8 @@ config("compiler") {
   if (export_libcxxabi_from_executables) {
     ldflags += [ "-Wl,-undefined,dynamic_lookup" ]
   }
+
+  cflags += [ "-Wno-unknown-warning-option" ]
 }
 
 # This is included by reference in the //build/config/compiler:runtime_library
@@ -125,3 +141,13 @@ if (mac_use_xcode_symlinks && current_toolchain == default_toolchain) {
     }
   }
 }
+
+# Swift runtime linkage for the Mori overlay's swift_source_set. macOS ships an
+# ABI-stable Swift runtime in /usr/lib/swift; link against the SDK stubs and add
+# an rpath so the framework that links Mori's Swift module resolves swift_*.
+config("swift_runtime") {
+  ldflags = [
+    "-L" + rebase_path(sysroot, root_build_dir) + "/usr/lib/swift",
+    "-Wl,-rpath,/usr/lib/swift",
+  ]
+}
